{
    "name": "smart-spmb-pro/smart-spmb-pro-web",
    "description": "Smart SPMB Pro - Sistem Penerimaan Murid Baru Berbasis Web",
    "version": "1.0.0",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "AiWerek Tech",
            "email": "aiwerek.tech@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5",
        "phpoffice/phpspreadsheet": "^2.0",
        "dompdf/dompdf": "^2.0",
        "endroid/qr-code": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "giorgiosironi/eris": "^0.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Property\\": "tests/property/",
            "Tests\\Unit\\": "tests/unit/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform-check": false,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
